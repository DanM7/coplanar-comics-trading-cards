# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Dev-only auth bypass (adds a Credentials provider named "Dev Bypass").
# Uses JWT sessions (required for credentials sign-in). Never enable in production.
DEV_AUTH_BYPASS="true"
NEXT_PUBLIC_DEV_AUTH_BYPASS="true"

# Card design editor at /editor (set true for local dev)
ENABLE_CARD_EDITOR="true"
NEXT_PUBLIC_ENABLE_CARD_EDITOR="true"

# OAuth providers (configure in provider consoles)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
