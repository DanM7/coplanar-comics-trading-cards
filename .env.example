# Database — use a Neon Postgres connection string (dev branch locally, main branch on Netlify).
# Example: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Dev-only auth bypass (adds a Credentials provider named "Dev Bypass").
# Uses JWT sessions (required for credentials sign-in). Never enable in production.
DEV_AUTH_BYPASS="true"
NEXT_PUBLIC_DEV_AUTH_BYPASS="true"

# Card design editor at /editor (set true for local dev only)
ENABLE_CARD_EDITOR="true"
NEXT_PUBLIC_ENABLE_CARD_EDITOR="true"

# OAuth providers — configure in each provider console (see docs/DEPLOYMENT-NETLIFY-NEON.md)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
